{
	"schemaVersion": 1,
	"id": "dlssmc",
	"version": "${version}",
	"name": "DLSSmc",
	"description": "NVIDIA DLSS Super Resolution & Frame Generation for Minecraft Java Edition via the Vulkan renderer",
	"authors": [
		"jhp"
	],
	"contact": {
		"sources": "https://github.com/lukeclaw/dlssmc"
	},
	"license": "CC0-1.0",
	"icon": "assets/dlssmc/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.jhp.DLSSmc"
		],
		"client": [
			"com.jhp.client.DLSSmcClient"
		]
	},
	"mixins": [
		"dlssmc.mixins.json",
		{
			"config": "dlssmc.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.3-",
		"java": ">=25",
		"fabric-api": "*"
	}
}